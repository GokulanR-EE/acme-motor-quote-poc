# Set a real key for live LLM mode:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# When 1, the app uses the deterministic offline extractor (no API key):
MOCK_LLM=1
# Quote service backend: "fake" (in-process) or "platform" (HTTP to PLATFORM_URL):
QUOTE_SERVICE=fake
PLATFORM_URL=http://localhost:8070
# Production integration layer (an MCP-backed adapter could target this):
MCP_URL=http://localhost:8090/mcp
