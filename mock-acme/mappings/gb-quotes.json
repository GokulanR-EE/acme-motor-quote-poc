{
  "mappings": [
    {
      "name": "gb-quote-comprehensive",
      "request": {
        "method": "POST",
        "urlPath": "/gb/quotes",
        "bodyPatterns": [
          { "matchesJsonPath": { "expression": "$.cover_tier", "equalTo": "comprehensive" } }
        ]
      },
      "response": {
        "status": 200,
        "headers": { "Content-Type": "application/json" },
        "transformers": ["response-template"],
        "jsonBody": {
          "quote_ref": "Q-{{jsonPath request.body '$.identifier'}}",
          "annual_premium": "{{math (math (math (math (math (math (jsonPath request.body '$.insurance_group') '*' 12) '+' 200) '*' (math 2.0 '-' (math (jsonPath request.body '$.age') '*' 0.02))) '*' (math 1 '-' (math (jsonPath request.body '$.ncb_years') '*' 0.05))) '*' (math 1 '-' (math (jsonPath request.body '$.voluntary_excess') '*' 0.0002))) '*' 1.0}}"
        }
      }
    },
