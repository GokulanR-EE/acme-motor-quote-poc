{
  "mappings": [
    {
      "name": "fr-quote-tous_risques",
      "request": {
        "method": "POST",
        "urlPath": "/fr/quotes",
        "bodyPatterns": [
          { "matchesJsonPath": { "expression": "$.formule", "equalTo": "tous_risques" } }
        ]
      },
      "response": {
        "status": 200,
        "headers": { "Content-Type": "application/json" },
        "transformers": ["response-template"],
        "jsonBody": {
          "quote_ref": "Q-{{jsonPath request.body '$.identifier'}}",
          "annual_premium": "{{math (math (math (math (jsonPath request.body '$.value') '*' 0.015) '+' 150) '*' (jsonPath request.body '$.bonus_malus')) '*' (math 1.0 '*' (math 1 '-' (math (jsonPath request.body '$.franchise') '*' 0.0001)))}}"
        }
      }
    },
    {
